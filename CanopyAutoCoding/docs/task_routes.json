          "tui_redirect_changed",
          "vendor_or_model_normalization_changed",
          "workflow_flag_surface_changed",
          "workflow_stage_set_changed",
          "wrapper_target_changed"
        ]
      },
      {
        "id": "stop_and_verify_flags",
        "used_in": [
          "docs/task_routes.json routes[].stop_and_verify_flags"
