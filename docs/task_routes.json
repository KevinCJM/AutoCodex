{
  "schema_version": "1.1",
  "scope_mode": "subtree_only",
  "allowed_unresolved_sentinels": ["unknown", "out_of_scope", "needs_code_confirmation"],
  "selector_contract": {
    "selector_types": {
      "literal": {
        "required": ["type", "path"],
        "output": "exact_path",
        "path_policy": "relative_to_scope_root_no_parent_segments"
      },
      "subtree": {
        "required": ["type", "path"],
        "output": "subtree_anchor",
        "enumeration_policy": "do_not_auto_enumerate_descendants"
      },
      "token": {
        "required": ["type", "token"],
        "output": "resolver_defined"
      },
      "field_ref": {
        "required": ["type", "field"],
        "allowed_fields": [
          "entry_selectors",
          "first_read_selectors",
          "then_check_selectors",
          "related_test_selectors",
          "related_config_selectors",
          "minimum_regression_selectors",
          "read_before_edit_selectors"
        ],
        "output": "inline_same_module_field"
      },
      "owned_paths_role": {
        "required": ["type", "role"],
        "output": "owned_paths_filtered_by_role"
      }
    },
    "token_registry": {
      "matched_stage_entry": {
        "resolver_inputs": ["task_text", "route_id", "M03_stage_family.owned_paths[role=stage_entry]"],
        "output_type": "literal",
        "fallback": "needs_code_confirmation"
      },
      "matched_prompt_file": {
        "resolver_inputs": ["task_text", "route_id", "M04_prompt_contracts.owned_paths[role=business_prompt]"],
        "output_type": "literal",
        "fallback": "needs_code_confirmation"
      },
      "matched_shared_file": {
        "resolver_inputs": ["task_text", "M08_shared_support.owned_paths"],
        "output_type": "literal",
        "fallback": "needs_code_confirmation"
      },
      "matched_failing_test": {
        "resolver_inputs": ["test_failure_identifier", "task_text"],
        "output_type": "literal",
        "fallback": "needs_code_confirmation"
      },
      "nearest_tested_module": {
        "resolver_inputs": ["matched_failing_test", "repo_map.relations"],
        "output_type": "module_id_or_selector",
        "fallback": "needs_code_confirmation"
      },
      "implementation_under_test": {
        "resolver_inputs": ["matched_failing_test", "import_trace_inside_scope"],
        "output_type": "literal_or_subtree",
        "fallback": "needs_code_confirmation"
      },
      "direct_callers": {
        "resolver_inputs": ["selected_path", "visible_import_or_call_trace"],
        "output_type": "literal_list",
        "fallback": "needs_code_confirmation"
      },
      "specific_requested_generated_path": {
        "resolver_inputs": ["task_text", "M10_generated_artifacts.owned_paths"],
        "output_type": "literal_or_subtree",
        "fallback": "needs_code_confirmation"
      },
      "generator_or_test_for_artifact": {
        "resolver_inputs": ["specific_requested_generated_path", "repo_map.relations", "related_test_selectors"],
        "output_type": "literal_or_module_ref",
        "fallback": "needs_code_confirmation"
      }
    }
  },
  "resolution_model": {
    "module_source": "docs/repo_map.json modules[]",
    "route_source": "docs/task_routes.json routes[]",
    "operations": [
      {
        "step": 1,
        "op": "match_routes",
        "input_fields": ["routes[].match_keywords", "routes[].negative_keywords", "routes[].route_priority"],
        "output_field": "matched_routes",
        "dedupe_key": ["route_id"]
      },
      {
        "step": 2,
        "op": "collect_module_defaults",
        "input_fields": ["routes[].first_read_modules"],
        "module_fields": [
          "first_read_selectors",
          "then_check_selectors",
          "related_test_selectors",
          "related_config_selectors",
          "minimum_regression_selectors"
        ],
        "output_fields": [
          "first_read_selectors",
          "then_check_selectors",
          "related_test_selectors",
          "related_config_selectors",
          "minimum_regression_selectors"
        ],
        "dedupe_key": ["type", "path", "token", "field", "role"]
      },
      {
        "step": 3,
        "op": "apply_route_deltas",
        "input_fields": ["routes[].selector_deltas"],
        "merge": "append",
        "dedupe_key": ["type", "path", "token", "field", "role"]
      },
      {
        "step": 4,
        "op": "apply_route_overrides",
        "input_fields": ["routes[].selector_overrides"],
        "merge": "replace_named_output_field",
        "dedupe_key": ["type", "path", "token", "field", "role"]
      },
      {
        "step": 5,
        "op": "materialize_selectors",
        "input_fields": [
          "first_read_selectors",
          "then_check_selectors",
          "related_test_selectors",
          "related_config_selectors",
          "minimum_regression_selectors"
        ],
        "selector_contract_ref": "#/selector_contract",
        "fallback_policy": "emit_allowed_unresolved_sentinel"
      }
    ]
  },
  "cross_file_validation": {
    "module_ids": "routes[].first_read_modules and pitfalls[].affected_modules must exist in repo_map.modules[].id",
    "pitfall_ids": "modules[].pitfall_ids and routes[].pitfall_ids must exist in pitfalls.pitfalls[].id",
    "relation_targets": "repo_map.modules[].relations[].target must exist in repo_map.modules[].id",
    "selector_tokens": "every selector type=token must exist in selector_contract.token_registry",
    "selector_fields": "every selector type=field_ref must use selector_contract.selector_types.field_ref.allowed_fields",
    "literal_path_policy": "literal/subtree paths must stay inside scope root and must not contain parent traversal",
    "allowed_unresolved_sentinels_ref": "#/allowed_unresolved_sentinels"
  },
  "condition_code_registry": {
    "expand_search_codes": {
      "TX01": "module_reference_ambiguous",
      "TX02": "wrapper_target_unconfirmed",
      "TX03": "cross_module_contract_touched",
      "TX04": "external_runtime_implicated",
      "TX05": "frontend_backend_protocol_touched",
      "TX06": "prompt_contract_boundary_touched",
      "TX07": "generated_artifact_boundary_touched"
    },
    "stop_codes": {
      "SV01": "out_of_scope_path",
      "SV02": "pitfall_gate_triggered",
      "SV03": "routing_conflict_with_visible_truth"
    }
  },
  "routes": [
    {
      "id": "R01_routing_layer",
      "task_type": "routing_layer_creation_or_validation",
      "match_keywords": ["routing_layer", "agents_md", "repo_map", "task_routes", "pitfalls", "machine_first", "audit"],
      "negative_keywords": ["human_docs", "architecture_overview"],
      "route_priority": 100,
      "first_read_modules": ["M09_routing_init_layer", "M04_prompt_contracts", "M11_tests"],
      "selector_deltas": {},
      "selector_overrides": {},
      "pitfall_ids": ["P02", "P06", "P08"],
      "expand_search_codes": ["TX03", "TX06", "TX07"],
      "stop_codes": ["SV01", "SV02", "SV03"]
    },
    {
      "id": "R02_workflow_entry",
