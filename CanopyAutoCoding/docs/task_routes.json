{
  "schema_version": "1.2",
  "scope_mode": "subtree_only",
  "resolution_model": {
    "derive_from_modules": [
      "first_read_files",
      "then_check_files",
      "related_tests",
      "related_configs",
      "minimum_regression",
      "expand_search_flags"
    ],
    "module_order_source": "first_read_modules listed order",
    "module_merge_direction": "left_to_right",
    "dedupe_strategy": "stable_first_seen_exact_string",
    "route_appends_field": "route_appends",
    "route_expand_search_flags_field": "route_expand_search_flags",
    "route_overrides_field": "route_overrides",
    "merge_steps": [
      "1_module_derived",
      "2_route_appends_then_dedupe",
      "3_route_expand_search_flags_then_dedupe",
      "4_route_overrides_replace_field"
    ],
    "override_semantics": "if route_overrides[field] exists, ignore derived and appended values for that field and use the override exactly",
    "missing_field_semantics": "omitted route_appends, route_expand_search_flags, and route_overrides mean inherit-with-no-route-delta",
    "sparse_encoding": {
      "omit_empty_route_appends": true,
      "omit_empty_route_expand_search_flags": true,
      "omit_empty_route_overrides": true
    }
  },
  "flag_vocab": {
    "unknown_flag_policy": "treat unknown flags as schema drift until this registry is updated",
    "domains": [
      {
        "id": "expand_search_flags",
        "used_in": [
          "docs/repo_map.json modules[].expand_search_flags",
          "docs/task_routes.json routes[].route_expand_search_flags"
        ],
        "allowed_values": [
