{
  "schema_version": "1.2",
  "scope_mode": "subtree_only",
  "selector_contract": {
    "selector_fields": [
      "first_read_selectors",
      "then_check_selectors",
      "read_before_edit_selectors"
    ],
    "selector_types": [
      {
        "id": "literal_path",
        "required_fields": [
          "path"
        ]
      },
      {
        "id": "owned_paths_role",
        "required_fields": [
          "role"
        ]
      },
      {
        "id": "field_ref",
        "required_fields": [
          "field"
        ],
        "allowed_fields": [
          "first_read_selectors",
          "then_check_selectors"
        ]
      }
    ],
    "selector_contexts": {
      "module_selector_fields": {
        "container_paths": [
          "modules[].first_read_selectors",
          "modules[].then_check_selectors",
          "modules[].read_before_edit_selectors"
        ],
        "binding_module_policy": "current_module"
      },
      "route_selector_fields": {
        "container_paths": [
          "routes[].route_selector_appends",
          "routes[].route_then_check_appends",
          "routes[].route_overrides.first_read_selectors",
          "routes[].route_overrides.then_check_selectors"
        ],
        "literal_path_binding": "none",
        "non_literal_binding_required_for": [
          "owned_paths_role",
          "field_ref"
        ],
        "non_literal_binding_field": "module_id",
        "non_literal_binding_validation": "selector.module_id must reference one module id listed in route.first_read_modules",
        "bound_module_usage": {
          "owned_paths_role": "scan only the bound module owned_paths",
          "field_ref": "inline only the bound module selector field"
        },
        "omitted_non_literal_binding_policy": "invalid"
      }
    },
    "resolution_output": {
      "kind": "ordered_path_anchor_list",
      "anchor_fields": [
        "path",
        "match",
        "role",
        "origin_field"
      ],
      "origin_field_semantics": "the selector field currently being materialized into output anchors",
      "origin_field_allowed_values": [
        "first_read_selectors",
        "then_check_selectors",
        "read_before_edit_selectors"
      ],
      "origin_field_assignment_scope": "set from the active output selector field before expansion and preserved unchanged through recursion and materialization",
      "directory_anchor_policy": "if a materialized anchor has match=subtree, the directory root path itself is the read target",
      "enumeration_policy": "never auto-enumerate descendants from subtree anchors",
      "dedupe_basis": [
        "path",
        "match",
        "role",
        "origin_field"
      ]
    },
    "expansion_algorithm": [
      {
        "step": 0,
        "op": "enter_selector_field_frame",
        "input": "one selector field listed in selector_fields",
        "set_active_origin_field_from": "input.selector_field",
        "active_origin_field_constraints": "must remain one of resolution_output.origin_field_allowed_values for the full expansion frame"
      },
      {
        "step": 1,
        "op": "literal_path_passthrough",
        "selector_type": "literal_path",
        "ordering": "preserve_selector_order",
        "materialize_as": {
          "path_source": "selector.path",
          "match": "exact",
          "role": null,
          "origin_field_source": "active_origin_field"
        },
        "route_level_binding": "not_applicable"
      },
      {
        "step": 2,
        "op": "field_ref_inline",
        "selector_type": "field_ref",
        "lookup_scope": "same_module_only",
        "ordering": "depth_first_preserve_referenced_order",
        "cycle_policy": "invalid",
        "origin_field_policy": "preserve_active_origin_field",
        "route_level_binding_policy": "when selector is stored in a route selector field, resolve lookup_scope against selector.module_id and reject if selector.module_id is missing or invalid"
      },
      {
        "step": 3,
        "op": "owned_paths_role_scan",
        "selector_type": "owned_paths_role",
        "source": "modules[].owned_paths",
        "lookup_scope": "same_module_only",
        "ordering": "preserve_owned_paths_declaration_order",
        "filter": "owned_path.role == selector.role",
        "route_level_binding_policy": "when selector is stored in a route selector field, scan only the module identified by selector.module_id and reject if selector.module_id is missing or invalid"
      },
      {
        "step": 4,
        "op": "owned_path_materialize",
        "source": "matched_owned_path",
        "exact_match_output": "emit_exact_path_anchor",
        "subtree_match_output": "emit_subtree_root_anchor_only",
        "materialized_anchor_fields": {
          "path_source": "matched_owned_path.path",
          "match_source": "matched_owned_path.match",
          "role_source": "matched_owned_path.role",
          "origin_field_source": "active_origin_field"
        }
      },
      {
        "step": 5,
        "op": "dedupe",
        "strategy": "stable_first_seen_exact_tuple",
        "tuple_fields": [
          "path",
          "match",
          "role",
          "origin_field"
        ]
      }
    ]
  },
  "resolution_model": {
    "module_owned_fields": [
      "first_read_selectors",
      "then_check_selectors",
      "related_tests",
      "related_configs",
      "minimum_regression"
    ],
    "module_order_source": "first_read_modules",
    "route_delta_fields": {
      "route_selector_appends": "append_to_first_read_selectors",
      "route_then_check_appends": "append_to_then_check_selectors",
      "route_test_appends": "append_to_related_tests",
      "route_config_appends": "append_to_related_configs",
      "route_regression_appends": "append_to_minimum_regression"
    },
    "route_override_fields": [
      "first_read_selectors",
      "then_check_selectors",
      "related_tests",
      "related_configs",
      "minimum_regression"
    ],
    "selector_contract_ref": "#/selector_contract",
    "delta_application_order": [
      "route_selector_appends",
      "route_then_check_appends",
      "route_test_appends",
      "route_config_appends",
      "route_regression_appends"
    ],
    "merge_steps": [
      "1_collect_module_owned_fields_from_first_read_modules_in_listed_order",
      "2_apply_route_delta_fields_in_delta_application_order",
      "3_apply_route_overrides_as_exact_replacement_for_named_fields",
      "4_dedupe_each_result_field_using_dedupe_strategy"
    ],
    "override_precedence": "route_overrides replace module-derived and route-appended values for the named field exactly",
    "missing_field_semantics": "omitted route delta or override fields mean no route-level modification for that field",
    "dedupe_strategy": "stable_first_seen_exact_value"
  },
  "condition_code_registry": {
    "module_expand_search_codes": {
      "MX01": "workflow_stage_surface_changed",
